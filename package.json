    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "keywords": [
    "dictation",
    "whisper",
    "voice",
    "electron"
  ],
  "author": "OpenFlow Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openflow-app/openflow.git"
  },
  "homepage": "https://openflow.app",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.17.1",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-store": "^8.2.0",
    "ffmpeg-static": "^5.3.0",
    "groq-sdk": "^0.3.3",
    "node-global-key-listener": "^0.3.0",
    "openai": "^4.28.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "simple-icons": "^16.18.0",
    "smart-whisper": "^0.8.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^29.1.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "eslint": "^8.56.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
